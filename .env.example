# MongoDB Connection URI
# For local development: Keep default (localhost)
# For production: Set to your MongoDB Atlas connection string
# Get from MongoDB Atlas: https://account.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=mongodb://localhost:27017/github_webhook

# Flask Port (Optional, defaults to 5000)
PORT=5000

# Flask Environment (development or production)
FLASK_ENV=development